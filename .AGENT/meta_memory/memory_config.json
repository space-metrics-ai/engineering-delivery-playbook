{
  "$schema": "memory_config",
  "description": "Memory management configuration - Task reflections and settings",
  "config": {
    "max_conversations": 50,
    "max_decisions": 100,
    "auto_cleanup_days": 90,
    "reflection_interval": "weekly"
  },
  "memory_types": {
    "working_memory": {
      "description": "What am I doing now?",
      "purpose": "Active session context",
      "persistence": "session",
      "files": ["context.json", "stack.json"]
    },
    "procedural_memory": {
      "description": "How do I do this?",
      "purpose": "How-to knowledge",
      "persistence": "permanent",
      "files": ["PROFILES.md", "skills/"]
    },
    "semantic_memory": {
      "description": "What do I know?",
      "purpose": "Stored knowledge",
      "persistence": "permanent",
      "files": ["project/", "entities/"]
    },
    "episodic_memory": {
      "description": "What happened before?",
      "purpose": "Past activity",
      "persistence": "rolling",
      "files": ["conversations/", "decisions/"]
    },
    "meta_memory": {
      "description": "How can I improve memory?",
      "purpose": "Memory management",
      "persistence": "permanent",
      "files": ["memory_config.json", "reflections.jsonl"]
    }
  }
}
